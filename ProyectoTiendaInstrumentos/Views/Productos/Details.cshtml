@model VwDetallesProducto
@using ProyectoTiendaInstrumentos.Extensions
@using ProyectoTiendaInstrumentos.Models
@{
    ViewData["Title"] = Model.NombreMarca + " " + Model.Modelo;
    List<VwEspecificacionesProducto> specs = ViewBag.Especificaciones as List<VwEspecificacionesProducto>;
    List<ProductoImagen> imagenesProducto = ViewBag.ImagenesProductos as List<ProductoImagen>;
    bool usuarioHaValorado = ViewBag.UsuarioHaValorado ?? false;
    bool usuarioHaComprado = ViewBag.UsuarioHaComprado ?? false;
    bool estaAutenticado = Context.User.Identity.IsAuthenticated;
    PagedResult<VwValoracionesProducto> paginacionResenas = ViewBag.PaginacionResenas as PagedResult<VwValoracionesProducto>;
    int stock = Model.Stock ?? 0;
    int maxCantidad = Math.Min(10, stock);
}

<div class="pd-topbar">
    <a asp-controller="Productos" asp-action="Index" asp-route-idSubtipo="@Model.IdSubtipo" class="pd-back-link">
        <i class="bi bi-arrow-left"></i> Volver al catálogo
    </a>
    @if (Context.User.FindFirst("Admin") != null)
    {
        <div class="pd-admin-bar">
            <a asp-controller="Productos" asp-action="Editar" asp-route-idProducto="@Model.IdProducto" class="admin-btn admin-btn--md admin-btn--warning">
                <i class="bi bi-pencil"></i> Editar
            </a>
            <form method="post" asp-controller="Productos" asp-action="EliminarPost" style="display:inline;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="idProducto" value="@Model.IdProducto" />
                <input type="hidden" name="idSubtipo" value="@Model.IdSubtipo" />
                <button type="submit" class="admin-btn admin-btn--md admin-btn--danger" onclick="return confirm('¿Eliminar este producto?')">
                    <i class="bi bi-trash"></i> Eliminar
                </button>
            </form>
        </div>
    }
</div>

<div class="pd-layout">

    <div class="pd-gallery-col">
        <div class="pd-main-image-wrap">
            <img id="main-product-image"
                 class="pd-main-image"
                 src="~/images/productosMain/@Model.Imagen"
                 alt="@Model.Modelo"
                 style="display:block;max-width:100%;height:auto;max-height:520px;object-fit:contain;" />
        </div>

        @if (imagenesProducto != null && imagenesProducto.Count > 0)
        {
            <div class="pd-thumbnails">
                <div class="pd-thumb-item pd-thumb-active"
                     data-src="@Url.Content("~/images/productosMain/" + Model.Imagen)">
                    <img src="~/images/productosMain/@Model.Imagen" alt="@Model.Modelo" style="display:block;width:100%;height:100%;object-fit:contain;" />
                </div>
                @foreach (ProductoImagen imagen in imagenesProducto)
                {
                    <div class="pd-thumb-item"
                         data-src="@Url.Content("~/images/productos/" + imagen.Imagen)">
                        <img src="~/images/productos/@imagen.Imagen" alt="@Model.Modelo" style="display:block;width:100%;height:100%;object-fit:contain;" />
                    </div>
                }
            </div>
        }
    </div>

    <div class="pd-info-col">

        <div class="pd-brand-row">
            <img src="~/images/marcas/@Model.LogoMarca" alt="@Model.NombreMarca" class="pd-brand-logo" style="display:block;width:54px;height:54px;max-width:54px;max-height:54px;object-fit:contain;" />
            <span class="pd-brand-name">@Model.NombreMarca</span>
            @if (Model.PuntuacionMarca > 0)
            {
                <div class="pd-brand-rating">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="bi bi-star@(i <= Model.PuntuacionMarca ? "-fill" : "")"></i>
                    }
                </div>
            }
        </div>

        <h1 class="pd-title">@Model.NombreMarca @Model.Modelo</h1>

        @if (Model.Puntuacion > 0)
        {
            <div class="pd-rating-row">
                <div class="pd-stars">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="bi bi-star@(i <= Model.Puntuacion ? "-fill" : "")"></i>
                    }
                </div>
                <span class="pd-rating-value">@Model.Puntuacion / 5</span>
            </div>
        }

        <div class="pd-price-row">
            <span class="pd-price">@Model.Precio.ToString("N2") €</span>
            <span class="pd-price-tax">IVA incluido</span>
        </div>

        @if (stock < 1)
        {
            <div class="pd-stock pd-stock--out">
                <i class="bi bi-x-circle-fill"></i> Agotado — sin stock disponible
            </div>
        }
        else if (stock < 5)
        {
            <div class="pd-stock pd-stock--low">
                <i class="bi bi-exclamation-triangle-fill"></i> ¡Quedan solo @stock unidades!
            </div>
        }
        else
        {
            <div class="pd-stock pd-stock--ok">
                <i class="bi bi-check-circle-fill"></i> En stock — envío en 24/48h
            </div>
        }

        @if (stock > 0)
        {
            <form method="post" asp-action="AddToCart" class="pd-cart-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="idProducto" value="@Model.IdProducto" />
                <div class="pd-cart-row">
                    <div class="pd-qty-wrap">
                        <label class="pd-qty-label">Cantidad</label>
                        <select name="cantidad" class="pd-qty-select">
                            @for (int i = 1; i <= maxCantidad; i++)
                            {
                                <option value="@i" selected="@(i == 1)">@i</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="pd-btn-cart">
                        <i class="bi bi-cart-plus"></i> Añadir al carrito
                    </button>
                </div>
            </form>
        }
        else
        {
            <div class="pd-sold-out-cta">
                <i class="bi bi-bell"></i> Producto agotado temporalmente
            </div>
        }

        <div class="pd-meta-info">
            <span><i class="bi bi-fire"></i> @Model.Ventas ventas</span>
            <span><i class="bi bi-truck"></i> Envío rápido</span>
            <span><i class="bi bi-arrow-repeat"></i> Devolución fácil</span>
        </div>

        <div class="pd-description">
            <h3>Descripción</h3>
            <p>@Model.Descripcion</p>
        </div>

        @if (specs != null && specs.Count > 0)
        {
            <div class="pd-specs">
                <h3>Especificaciones técnicas</h3>
                <table class="pd-specs-table">
                    <tbody>
                        @foreach (VwEspecificacionesProducto spec in specs)
                        {
                            <tr>
                                <th>@spec.Especificacion</th>
                                <td>@spec.Valor @(spec.UnidadMedida != null && spec.UnidadMedida != "" ? " " + spec.UnidadMedida : "")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<section class="pd-reviews">
    <h2 class="pd-reviews-title">Reseñas de clientes</h2>

    @if (TempData["SuccessValoracion"] != null)
    {
        <div class="pd-alert pd-alert--success"><i class="bi bi-check-circle"></i> @TempData["SuccessValoracion"]</div>
    }
    @if (TempData["ErrorValoracion"] != null)
    {
        <div class="pd-alert pd-alert--danger"><i class="bi bi-exclamation-circle"></i> @TempData["ErrorValoracion"]</div>
    }

    @if (!estaAutenticado)
    {
        <p class="pd-review-notice">
            <i class="bi bi-info-circle"></i>
            Debes <a asp-controller="Cuenta" asp-action="Login">iniciar sesión</a> para dejar una reseña.
        </p>
    }
    else if (!usuarioHaComprado)
    {
        <p class="pd-review-notice"><i class="bi bi-bag"></i> Debes comprar este producto antes de poder valorarlo.</p>
    }
    else if (!usuarioHaValorado)
    {
        <button type="button" id="btnMostrarFormulario" class="pd-btn-review">
            <i class="bi bi-pencil-square"></i> Escribir una reseña
        </button>

        <div id="cajaComentario" class="pd-review-form-wrap" style="display:none;">
            <form method="post" asp-action="AddValoracion" class="pd-review-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="idProducto" value="@Model.IdProducto" />
                <div class="pd-form-group">
                    <label>Puntuación</label>
                    <select name="puntuacion" required class="pd-select">
                        <option value="">Selecciona una puntuación</option>
                        @for (int i = 5; i >= 1; i--)
                        {
                            <option value="@i">@i estrella@(i > 1 ? "s" : "")</option>
                        }
                    </select>
                </div>
                <div class="pd-form-group">
                    <label>Tu comentario</label>
                    <textarea name="comentario" rows="4" placeholder="Cuéntanos tu experiencia con este producto..." required class="pd-textarea"></textarea>
                </div>
                <div class="pd-form-actions">
                    <button type="submit" class="pd-btn-submit"><i class="bi bi-send"></i> Publicar reseña</button>
                    <button type="button" id="btnCancelar" class="pd-btn-cancel">Cancelar</button>
                </div>
            </form>
        </div>
    }
    else
    {
        <p class="pd-review-notice pd-review-notice--done">
            <i class="bi bi-check-circle-fill"></i> Ya has valorado este producto. ¡Gracias!
        </p>
    }

    <div class="pd-reviews-list">
        @{
            var valoraciones = ViewBag.Valoraciones as List<VwValoracionesProducto>;
        }

        @if (valoraciones != null && valoraciones.Count > 0)
        {
            @foreach (VwValoracionesProducto resena in valoraciones)
            {
                <div class="pd-review-card">
                    <div class="pd-review-header">
                        <img class="pd-review-avatar"
                             src="~/images/users/@resena.ImagenUsuario"
                             alt="@resena.NombreUsuario"
                             style="display:block;width:50px;height:50px;max-width:50px;max-height:50px;min-width:50px;min-height:50px;object-fit:cover;object-position:center;border-radius:999px;" />
                        <div class="pd-review-meta">
                            <span class="pd-review-author">@resena.NombreUsuario</span>
                            <div class="pd-review-stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="bi bi-star@(i <= resena.Puntuacion ? "-fill" : "")"></i>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="pd-review-body">
                        <p>@resena.Comentario</p>
                    </div>
                </div>
            }

            @if (paginacionResenas != null)
            {
                @await Html.PartialAsync("_Paginacion", (
                    paginacionResenas.PaginaActual,
                    paginacionResenas.TotalPaginas,
                    "Details",
                    "Productos",
                    (object)(new { idProducto = Model.IdProducto })
                ))
            }
        }
        else
        {
            <div class="pd-no-reviews">
                <i class="bi bi-chat-square-text"></i>
                <p>No hay reseñas todavía. ¡Sé el primero en opinar!</p>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        $(function () {
            var $mainImg = $('#main-product-image');

            $(document).on('click', '.pd-thumb-item', function () {
                var src = $(this).data('src');
                $mainImg.addClass('img-fade-out');
                setTimeout(function () {
                    $mainImg.attr('src', src);
                    $mainImg.removeClass('img-fade-out');
                }, 180);
                $('.pd-thumb-item').removeClass('pd-thumb-active');
                $(this).addClass('pd-thumb-active');
            });

            $(document).on('click', '#btnMostrarFormulario', function () {
                $('#cajaComentario').slideDown(250);
                $(this).hide();
            });

            $(document).on('click', '#btnCancelar', function () {
                $('#cajaComentario').slideUp(250);
                $('#btnMostrarFormulario').show();
                $('#cajaComentario form')[0]?.reset();
            });
        });
    </script>
}
