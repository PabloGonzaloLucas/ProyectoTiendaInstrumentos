@model VwDetallesProducto
@using ProyectoTiendaInstrumentos.Extensions
@using ProyectoTiendaInstrumentos.Models
@{
    List<VwEspecificacionesProducto> specs = ViewBag.Especificaciones as List<VwEspecificacionesProducto>;
    List<ProductoImagen> imagenesProducto = ViewBag.ImagenesProductos as List<ProductoImagen>;
    bool usuarioHaValorado = ViewBag.UsuarioHaValorado ?? false;
    bool usuarioHaComprado = ViewBag.UsuarioHaComprado ?? false;
    bool estaAutenticado = Context.User.Identity.IsAuthenticated;
    PagedResult<VwValoracionesProducto> paginacionResenas = ViewBag.PaginacionResenas as PagedResult<VwValoracionesProducto>;
}
<p><a asp-controller="Productos" asp-action="Index" asp-route-idSubtipo="@Model.IdSubtipo">Volver</a></p>
<div>
    @if (Context.User.FindFirst("Admin") != null)
    {
        <a asp-controller="Productos" asp-action="Editar" asp-route-idProducto="@Model.IdProducto">
            Editar
        </a>
        <a asp-controller="Productos" asp-action="Eliminar" asp-route-idProducto="@Model.IdProducto" asp-route-idSubtipo="@Model.IdSubtipo">
            Eliminar
        </a>
    }
    <h1>@(Model.NombreMarca + " " + Model.Modelo) </h1>
    <div>   
        <p><strong>@Model.Puntuacion</strong></p>
        <img src="~/images/marcas/@Model.LogoMarca" />
        <p>@Model.PuntuacionMarca</p>
        <div class="main-image-container">
            <img id="main-product-image"
                 class="main-product-image"
                 src="~/images/productosMain/@Model.Imagen"
                 alt="@Model.Modelo" />
        </div>

        @if (imagenesProducto != null && imagenesProducto.Count > 0)
        {
            <div class="thumbnail-strip">
                <div class="thumbnail-track-wrapper">
                    <div class="thumbnail-track">
                        <div class="gallery-image-container thumb-active"
                             data-src="@Url.Content("~/images/productosMain/" + Model.Imagen)">
                            <img class="gallery-image"
                                 src="~/images/productosMain/@Model.Imagen"
                                 alt="@Model.Modelo" />
                        </div>
                        @foreach (ProductoImagen imagen in imagenesProducto)
                        {
                            <div class="gallery-image-container"
                                 data-src="@Url.Content("~/images/productos/" + imagen.Imagen)">
                                <img class="gallery-image"
                                     src="~/images/productos/@imagen.Imagen"
                                     alt="@Model.Modelo" />
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        <p><strong>Descripción: </strong>@Model.Descripcion</p>
            @if(specs.Count > 0)
            {
                <table>
                    <thead>
                        @foreach(VwEspecificacionesProducto spec in specs)
                        {
                            <th>@spec.Especificacion</th>  
                        }
                        
                    </thead>
                    <tbody>
                        @foreach (VwEspecificacionesProducto spec in specs)
                        {
                            <td>
                                @spec.Valor 
                                @if(spec.UnidadMedida != null || spec.UnidadMedida != "")
                                {
                                     @(" "+spec.UnidadMedida)
                                }
                            </td>
                        }
                    </tbody>
                </table>
            }
            <div>
            <p><strong>@Model.Precio €</strong></p>
            @if (Model.Stock < 1)
            {
                <p>
                    <span style="color:red">No hay stock</span>
                </p>
            }
            else if (@Model.Stock < 5)
            {
                <p>
                    <span style="color:orange">Quedan pocas unidades!</span>
                </p>
            }
            else if (@Model.Stock >= 5)
            {
                <p>
                    <span style="color:green">En stock!</span>
                </p>
            }
           
            <form method="post" asp-action="AddToCart">
                @{
                    int stock = @Model.Stock ?? 0;
                    int maxCantidad = Math.Min(10, stock);
                }
                <input type="hidden" name="idProducto" value="@Model.IdProducto" />
                @if (stock == 0)
                {
                    <span>Agotado</span>
                }
                else if (stock > 0)
                {
                    <select name="cantidad" class="cantidad-select">
                        @for (int i = 1; i <= maxCantidad; i++)
                        {
                            <option value="@i" selected="@(i == 1)">
                                @i
                            </option>
                        }
                    </select>
                    <button type="submit">Añadir al carrito</button>
                }

            </form>
            <p>Ventas: @Model.Ventas</p>
        </div>
    </div>

    <div class="seccion-resenas">
        <h2>Reseñas</h2>

        @if (TempData["SuccessValoracion"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessValoracion"]</div>
        }

        @if (TempData["ErrorValoracion"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorValoracion"]</div>
        }

        @if (!estaAutenticado)
        {
            <p class="ya-valorado">Debes <a asp-controller="Cuenta" asp-action="Login">iniciar sesión</a> para dejar una reseña.</p>
        }
        else if (!usuarioHaComprado)
        {
            <p class="ya-valorado">Debes comprar este producto antes de poder valorarlo.</p>
        }
        else if (!usuarioHaValorado)
        {
            <button type="button" id="btnMostrarFormulario" class="btn-resena">Deja tu reseña</button>
            
            <div id="cajaComentario" class="caja-comentario" style="display: none;">
                <form method="post" asp-action="AddValoracion">
                    <input type="hidden" name="idProducto" value="@Model.IdProducto" />
                    
                    <div class="form-group-resena">
                        <label>Puntuación:</label>
                        <select name="puntuacion" required>
                            <option value="">Selecciona una puntuación</option>
                            @for(int i=5; i>=1; i--)
                            {
                                <option value="@i">@i estrellas</option>
                            }
                        </select>
                    </div>

                    <div class="form-group-resena">
                        <label>Tu comentario:</label>
                        <textarea name="comentario" rows="4" placeholder="Cuéntanos tu experiencia con este producto..." required></textarea>
                    </div>

                    <div class="botones-resena">
                        <button type="submit" class="btn-publicar">Publicar reseña</button>
                        <button type="button" id="btnCancelar" class="btn-cancelar">Cancelar</button>
                    </div>
                </form>
            </div>
        }
        else
        {
            <p class="ya-valorado">Ya has valorado este producto. ¡Gracias por tu opinión!</p>
        }

        <div class="resenas">
            @if(ViewBag.Valoraciones != null && ((List<VwValoracionesProducto>)ViewBag.Valoraciones).Count > 0)
            {
                @foreach(VwValoracionesProducto resena in ViewBag.Valoraciones as List<VwValoracionesProducto>)
                {
                    <div class="resena">
                        <div class="resena-header">
                            <img class="avatar-resena" 
                                 src="~/images/users/@resena.ImagenUsuario" 
                                 alt="@resena.NombreUsuario"
                                 style="width: 50px !important; height: 50px !important; min-width: 50px !important; min-height: 50px !important; max-width: 50px !important; max-height: 50px !important; border-radius: 50% !important; border: 3px solid #7FE3AA !important; object-fit: cover !important; display: block !important; flex-shrink: 0 !important;"/>
                            <div class="resena-info">
                                <span class="nombre-usuario">@resena.NombreUsuario</span>
                                <span class="puntuacion">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= resena.Puntuacion)
                                        {
                                            <i class="bi bi-star-fill" style="color: var(--primary-green);"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star" style="color: #ddd;"></i>
                                        }
                                    }
                                </span>
                            </div>
                        </div>
                        <div class="comentario">
                            <p>@resena.Comentario</p>
                        </div>
                    </div>       
                }

                @if (paginacionResenas != null)
                {
                    @await Html.PartialAsync("_Paginacion", (
                        paginacionResenas.PaginaActual,
                        paginacionResenas.TotalPaginas,
                        "Details",
                        "Productos",
                        (object)(new { idProducto = Model.IdProducto })
                    ))
                }
            }
            else
            {
                <p class="sin-resenas">No hay reseñas de este producto todavía. ¡Sé el primero en opinar!</p>
            }
        </div>

    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            // ── Galería de imágenes ───────────────────────────────────────────────
            var $mainImg = $('#main-product-image');

            $(document).on('click', '.gallery-image-container', function () {
                var src = $(this).data('src');
                $mainImg.addClass('img-fade-out');
                setTimeout(function () {
                    $mainImg.attr('src', src);
                    $mainImg.removeClass('img-fade-out');
                }, 180);
                $('.gallery-image-container').removeClass('thumb-active');
                $(this).addClass('thumb-active');
            });

            // ── Formulario de reseña ─────────────────────────────────────────────
            $(document).on('click', '#btnMostrarFormulario', function () {
                $('#cajaComentario').show();
                $('#btnMostrarFormulario').hide();
            });

            $(document).on('click', '#btnCancelar', function () {
                $('#cajaComentario').hide();
                $('#btnMostrarFormulario').show();
                $('#cajaComentario form')[0]?.reset();
            });
        });
    </script>
}


