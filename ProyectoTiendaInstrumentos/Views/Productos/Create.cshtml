@using ProyectoTiendaInstrumentos.Models
@using ProyectoTiendaInstrumentos.Repositories
@inject RepositorySubtipos repositorySubtipos

@{
    ViewData["Title"] = "Crear producto";
}

<div class="product-create">
    <div class="product-create__card">
        <h1 class="product-create__title">Crear producto</h1>

        <form method="post" enctype="multipart/form-data" class="product-create__form">
            @{
                SelectSubtiposProducto arbolTipos = ViewBag.ArbolTipos as SelectSubtiposProducto;
                bool hasArbol = arbolTipos != null;
            }

            <div class="product-create__group product-create__group--4">
                <label class="product-create__label" for="selectFamilia">Familia</label>
                <select name="idFamilia" id="selectFamilia" class="form-select product-create__control">
                    @if (hasArbol)
                    {
                        <option value="@arbolTipos.IdFamilia">@arbolTipos.NombreFamilia</option>
                    }
                    else
                    {
                        <option value="">Selecciona familia...</option>
                    }
                </select>
            </div>

            <div class="product-create__group product-create__group--4">
                <label class="product-create__label" for="selectTipo">Tipo</label>
                <select name="idTipo" id="selectTipo" class="form-select product-create__control">
                    @if (hasArbol)
                    {
                        <option value="@arbolTipos.IdTipo">@arbolTipos.NombreTipo</option>
                    }
                    else
                    {
                        <option value="">Selecciona tipo...</option>
                    }
                </select>
            </div>

            <div class="product-create__group product-create__group--4">
                <label class="product-create__label" for="selectSubtipo">Subtipo</label>
                <select name="idSubtipo" id="selectSubtipo" class="form-select product-create__control">
                    @if (hasArbol)
                    {
                        <option value="@arbolTipos.IdSubtipo">@arbolTipos.NombreSubtipo</option>
                    }
                    else
                    {
                        <option value="">Selecciona subtipo...</option>
                    }
                </select>
            </div>

            <div class="product-create__group product-create__group--6">
                <label class="product-create__label" for="modelo">Modelo</label>
                <input id="modelo" type="text" name="modelo" class="form-control product-create__control" />
            </div>

            <div class="product-create__group product-create__group--3">
                <label class="product-create__label" for="precio">Precio</label>
                <input id="precio" type="number" step="0.01" name="precio" class="form-control product-create__control" />
            </div>

            <div class="product-create__group product-create__group--3">
                <label class="product-create__label" for="stock">Stock</label>
                <input id="stock" type="number" name="stock" class="form-control product-create__control" />
            </div>

            <div class="product-create__group product-create__group--6">
                <label class="product-create__label" for="marca">Marca</label>
                <select id="marca" name="idMarca" class="form-select product-create__control">
                    @foreach (var marca in ViewBag.Marcas as List<Marca>)
                    {
                        <option value="@marca.IdMarca">@marca.Nombre</option>
                    }
                </select>
            </div>

            <div class="product-create__group product-create__group--6">
                <label class="product-create__label" for="imagen">Imagen principal</label>
                <input id="imagen" type="file" name="imagen" class="form-control product-create__control" />
            </div>

            <div class="product-create__group">
                <button type="button" id="botonMostrarFormImagenes" class="admin-btn product-create__section-btn">
                    <i class="bi bi-images"></i> Imágenes del producto
                </button>
            </div>

            <div id="zonaImagenes" class="product-create__panel" style="display:none;">
                <div style="display:flex; gap: 16px; align-items:flex-start; flex-wrap: wrap;">
                    <div id="contenedorImagenes" style="display:flex; flex-wrap:wrap; gap:10px;"></div>

                    <div style="min-width: 260px; flex: 1;">
                        <label class="product-create__label" for="inputImagenesProducto">Agregar imágenes</label>
                        <input type="file" id="inputImagenesProducto" name="imagenes" multiple accept="image/*" class="form-control product-create__control" />
                        <small class="product-create__hint">Se pueden seleccionar varias veces; se acumulan.</small>
                    </div>
                </div>
            </div>

            <div class="product-create__group">
                <label class="product-create__label" for="descripcion">Descripción</label>
                <textarea id="descripcion" name="descripcion" placeholder="Descripción del producto" class="form-control product-create__control"></textarea>
            </div>

            <div class="product-create__group">
                <button type="button" id="botonMostrarFormSpecs" class="admin-btn product-create__section-btn">
                    <i class="bi bi-list-check"></i> Especificaciones del producto
                </button>
            </div>

            <div id="zonaSpecs" class="product-create__panel" style="display:none;">
                <div style="display:flex; gap: 16px; align-items:flex-start; flex-wrap: wrap;">
                    <div style="min-width: 260px; flex: 1;">
                        <label class="product-create__label" for="selectEspecificacionesSubtipo">Agregar especificación</label>

                        <select id="selectEspecificacionesSubtipo" class="form-select product-create__control">
                            <option value="">Selecciona especificación...</option>
                        </select>

                        <input type="text" id="inputSpecValor" placeholder="Valor" class="form-control product-create__control" style="display:block; margin-top:8px;" />

                        <button type="button" id="botonAgregarSpec" class="btn btn-secondary" style="margin-top:8px;">Agregar especificación</button>

                        <small id="hintUnidad" class="product-create__hint"></small>
                    </div>

                    <div style="flex: 2; min-width: 280px;">
                        <label class="product-create__label">Especificaciones añadidas</label>
                        <div id="contenedorSpecs" style="display:flex; flex-direction:column; gap:8px; margin-top:8px;"></div>
                    </div>
                </div>
            </div>

            <div class="product-create__actions">
                <button type="submit" class="btn btn-primary product-create__submit">Crear producto</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            // --- Helpers ---
            function fillSelect($select, items, placeholder, selectedValue) {
                var current = selectedValue ?? $select.val();
                $select.empty();

                if (placeholder) {
                    $select.append($('<option/>', { value: '', text: placeholder }));
                }

                for (var i = 0; i < items.length; i++) {
                    $select.append($('<option/>', {
                        value: items[i].id,
                        text: items[i].nombre
                    }).attr('data-unidad', items[i].unidadMedida ?? ''));
                }

                if (current) {
                    $select.val(current);
                }
            }

            function hasValue(v) {
                return v !== undefined && v !== null && String(v).trim() !== '';
            }

            function setSpecValorInputTypeByUnidad(unidad) {
                var $input = $('#inputSpecValor');

                if (unidad === 'ud') {
                    // Cambia a number para unidades "ud"
                    $input.attr('type', 'number');
                    $input.attr('step', '1');
                    $input.attr('inputmode', 'numeric');
                } else {
                    // Vuelve a text para el resto
                    $input.attr('type', 'text');
                    $input.removeAttr('step');
                    $input.removeAttr('inputmode');
                }
            }

            function clearSpecsUI() {
                $('#selectEspecificacionesSubtipo').empty().append($('<option/>', { value: '', text: 'Selecciona especificación...' }));
                $('#inputSpecValor').val('');
                setSpecValorInputTypeByUnidad('');
                $('#hintUnidad').text('');
                $('#contenedorSpecs').empty();
            }

            function buildHiddenInputs(specId, valor) {
                // arrays para el model binder
                return (
                    '<input type="hidden" name="specIds" value="' + specId + '" />' +
                    '<input type="hidden" name="specValores" value="' + $('<div/>').text(valor).html() + '" />'
                );
            }

            // --- Carga perezosa familias/tipos/subtipos ---
            var familiasLoaded = false;
            var tiposLoadedForFamilia = null;
            var subtiposLoadedForTipo = null;

            var preFamilia = $('#selectFamilia').val();
            var preTipo = $('#selectTipo').val();
            var preSubtipo = $('#selectSubtipo').val();

            $('#selectFamilia').on('focus mousedown', function () {
                if (familiasLoaded) return;

                $.get('@Url.Action("Familias", "Catalogo")')
                    .done(function (data) {
                        familiasLoaded = true;
                        fillSelect($('#selectFamilia'), data, 'Selecciona familia...', preFamilia);
                        preFamilia = null;
                    })
                    .fail(function () {
                        alert('No se pudieron cargar las familias.');
                    });
            });

            $('#selectTipo').on('focus mousedown', function () {
                var idFamilia = $('#selectFamilia').val();
                if (!hasValue(idFamilia)) return;
                if (tiposLoadedForFamilia === idFamilia) return;

                $.get('@Url.Action("Tipos", "Catalogo")', { idFamilia: idFamilia })
                    .done(function (data) {
                        tiposLoadedForFamilia = idFamilia;
                        fillSelect($('#selectTipo'), data, 'Selecciona tipo...', preTipo);
                        preTipo = null;
                    })
                    .fail(function () {
                        alert('No se pudieron cargar los tipos.');
                    });
            });

            $('#selectSubtipo').on('focus mousedown', function () {
                var idTipo = $('#selectTipo').val();
                if (!hasValue(idTipo)) return;
                if (subtiposLoadedForTipo === idTipo) return;

                $.get('@Url.Action("Subtipos", "Catalogo")', { idTipo: idTipo })
                    .done(function (data) {
                        subtiposLoadedForTipo = idTipo;
                        fillSelect($('#selectSubtipo'), data, 'Selecciona subtipo...', preSubtipo);
                        preSubtipo = null;
                    })
                    .fail(function () {
                        alert('No se pudieron cargar los subtipos.');
                    });
            });

            $('#selectFamilia').on('change', function () {
                var idFamilia = $(this).val();

                tiposLoadedForFamilia = null;
                subtiposLoadedForTipo = null;

                fillSelect($('#selectTipo'), [], 'Selecciona tipo...');
                fillSelect($('#selectSubtipo'), [], 'Selecciona subtipo...');

                clearSpecsUI();

                if (!idFamilia) return;

                $.get('@Url.Action("Tipos", "Catalogo")', { idFamilia: idFamilia })
                    .done(function (data) {
                        tiposLoadedForFamilia = idFamilia;
                        fillSelect($('#selectTipo'), data, 'Selecciona tipo...');
                    })
                    .fail(function () {
                        alert('No se pudieron cargar los tipos.');
                    });
            });

            $('#selectTipo').on('change', function () {
                var idTipo = $(this).val();

                subtiposLoadedForTipo = null;

                fillSelect($('#selectSubtipo'), [], 'Selecciona subtipo...');

                clearSpecsUI();

                if (!idTipo) return;

                $.get('@Url.Action("Subtipos", "Catalogo")', { idTipo: idTipo })
                    .done(function (data) {
                        subtiposLoadedForTipo = idTipo;
                        fillSelect($('#selectSubtipo'), data, 'Selecciona subtipo...');
                    })
                    .fail(function () {
                        alert('No se pudieron cargar los subtipos.');
                    });
            });

            // --- Specs: mostrar/ocultar ---
            $('#botonMostrarFormSpecs').on('click', function () {
                $('#zonaSpecs').toggle();
            });

            // --- Cargar especificaciones por subtipo ---
            function loadSpecsForSubtipo(idSubtipo) {
                if (!hasValue(idSubtipo)) {
                    clearSpecsUI();
                    return;
                }

                $.get('@Url.Action("Especificaciones", "Catalogo")', { idSubtipo: idSubtipo })
                    .done(function (data) {
                        // data: [{id, nombre, unidadMedida}]
                        fillSelect($('#selectEspecificacionesSubtipo'), data, 'Selecciona especificación...');
                        $('#hintUnidad').text('');
                        setSpecValorInputTypeByUnidad('');
                    })
                    .fail(function () {
                        alert('No se pudieron cargar las especificaciones del subtipo.');
                    });
            }

            // cuando cambia subtipo, cargamos specs y limpiamos lista
            $('#selectSubtipo').on('change', function () {
                clearSpecsUI();
                loadSpecsForSubtipo($(this).val());
            });

            // si viene preseleccionado (ViewBag.ArbolTipos), carga specs al arrancar
            if (hasValue($('#selectSubtipo').val())) {
                loadSpecsForSubtipo($('#selectSubtipo').val());
            }

            // Grupo de specs añadidas para evitar duplicados
            var specsAdded = {}; // { specId: true }

            // hint unidad + tipo de input
            $('#selectEspecificacionesSubtipo').on('change', function () {
                var unidad = $(this).find('option:selected').data('unidad');

                if (hasValue(unidad)) {
                    $('#hintUnidad').text('Unidad: ' + unidad);
                } else {
                    $('#hintUnidad').text('');
                }

                setSpecValorInputTypeByUnidad(unidad);
                $('#inputSpecValor').val('');
            });

            // Añadir spec
            $('#botonAgregarSpec').on('click', function () {
                var specId = $('#selectEspecificacionesSubtipo').val();
                var specNombre = $('#selectEspecificacionesSubtipo option:selected').text();
                var unidad = $('#selectEspecificacionesSubtipo option:selected').data('unidad');
                var valor = $('#inputSpecValor').val();

                if (!hasValue(specId)) {
                    alert('Selecciona una especificación.');
                    return;
                }
                if (!hasValue(valor)) {
                    alert('Introduce un valor para la especificación.');
                    return;
                }
                if (specsAdded[specId]) {
                    alert('Esa especificación ya está añadida.');
                    return;
                }

                specsAdded[specId] = true;

                var $row = $('<div/>', {
                    'class': 'spec-row',
                    'css': {
                        'display': 'flex',
                        'alignItems': 'center',
                        'justifyContent': 'space-between',
                        'gap': '12px',
                        'border': '1px solid #ddd',
                        'borderRadius': '8px',
                        'padding': '8px 10px'
                    }
                });

                var texto = specNombre + ': ' + valor + (hasValue(unidad) ? (' ' + unidad) : '');
                var $text = $('<div/>', { text: texto });

                var $remove = $('<button/>', {
                    type: 'button',
                    text: 'Quitar',
                    'class': 'admin-btn admin-btn--lg admin-btn--delete'
                }).on('click', function () {
                    delete specsAdded[specId];
                    $row.remove();
                });

                // hidden inputs para el POST
                var $hidden = $('<div/>').html(buildHiddenInputs(specId, valor));

                $row.append($text, $hidden, $remove);
                $('#contenedorSpecs').append($row);

                // reset inputs
                $('#selectEspecificacionesSubtipo').val('');
                $('#inputSpecValor').val('');
                $('#hintUnidad').text('');
                setSpecValorInputTypeByUnidad('');
            });

        });
    </script>

    <script>
        // Imágenes secundarias
        $(function () {
            var dt = new DataTransfer();

            $('#botonMostrarFormImagenes').on('click', function () {
                $('#zonaImagenes').toggle();
            });

            function renderPreview(file, index) {
                var $item = $('<div/>', {
                    'class': 'preview-item preview-new',
                    'attr': { 'data-index': index },
                    'css': {
                        'position': 'relative',
                        'width': '90px',
                        'height': '90px',
                        'border': '1px solid #ddd',
                        'border-radius': '8px',
                        'overflow': 'hidden'
                    }
                });

                var reader = new FileReader();
                reader.onload = function (ev) {
                    var $img = $('<img/>', {
                        src: ev.target.result,
                        alt: file.name,
                        css: { width: '100%', height: '100%', objectFit: 'cover' }
                    });
                    $item.prepend($img);
                };
                reader.readAsDataURL(file);

                var $remove = $('<button/>', {
                    type: 'button',
                    text: 'X',
                    'css': { position: 'absolute', top: '4px', right: '4px' }
                }).on('click', function () {
                    // reconstruimos DataTransfer sin el índice quitado
                    var removeIndex = parseInt($item.attr('data-index'));
                    var newDt = new DataTransfer();

                    // quitar preview
                    $item.remove();

                    // reindexar y reconstruir
                    var newIndex = 0;
                    $('.preview-item.preview-new').each(function () {
                        var oldIndex = parseInt($(this).attr('data-index'));
                        if (oldIndex === removeIndex) return;

                        var f = dt.files[oldIndex];
                        if (f) {
                            newDt.items.add(f);
                            $(this).attr('data-index', newIndex++);
                        }
                    });

                    dt = newDt;
                    $('#inputImagenesProducto')[0].files = dt.files;
                });

                $item.append($remove);
                $('#contenedorImagenes').append($item);
            }

            $('#inputImagenesProducto').on('change', function (e) {
                var files = e.target.files;
                if (!files || files.length === 0) return;

                for (var i = 0; i < files.length; i++) {
                    dt.items.add(files[i]);
                    renderPreview(files[i], dt.files.length - 1);
                }

                // IMPORTANT: conservar acumulado en el input real
                this.files = dt.files;

                // No vaciar el input, porque perderíamos la selección.
                // Si quieres permitir volver a seleccionar el mismo archivo, se puede usar un input "proxy".
            });
        });
    </script>
}