@model List<VwCatalogoProducto>
@{
    ViewData["Title"] = "Catálogo";
    string termino = ViewBag.TerminoBusqueda ?? "";
    int numResultados = ViewBag.NumeroResultados ?? 0;
    bool esBusqueda = !string.IsNullOrEmpty(termino);

    Subtipo subtipo = ViewBag.Subtipo as Subtipo;
}

@if (esBusqueda)
{
    <div class="busqueda-header">
        <h1>Resultados de búsqueda</h1>
        <p class="termino-busqueda">
            Búsqueda: <strong>"@termino"</strong>
            <span class="num-resultados">(@numResultados @(numResultados == 1 ? "producto encontrado" : "productos encontrados"))</span>
        </p>
    </div>
}
else
{
    <h1>@(subtipo != null ? subtipo.Nombre : "Catálogo")</h1>
    @if (subtipo != null)
    {
        <p>
            <a asp-controller="Subtipos" asp-action="Index" asp-route-idTipo="@subtipo.IdTipo">@subtipo.Nombre</a>
        </p>
    }
}

@if (Model != null && Model.Count > 0)
{
    <div class="productos-grid">
        @foreach (VwCatalogoProducto producto in Model)
        {
            <div class="producto-card">
                <a asp-controller="Productos" asp-action="Details" asp-route-idProducto="@producto.IdProducto" class="producto-link">
                    <div class="producto-image-container">
                        <img src="~/images/productosMain/@producto.ImagenPrincipal" alt="@producto.Modelo" class="producto-image" />
                        @if (producto.Stock < 1)
                        {
                            <div class="badge-agotado">Agotado</div>
                        }
                        else if (producto.Stock < 5)
                        {
                            <div class="badge-pocas">Pocas unidades</div>
                        }
                    </div>

                    <div class="producto-info">
                        <div class="producto-marca">@producto.Marca</div>
                        <h3 class="producto-nombre">@producto.Modelo</h3>

                        <div class="producto-categoria">
                            <i class="bi bi-tag"></i> @producto.Tipo - @producto.Subtipo
                        </div>

                        @if (producto.Estrellas > 0)
                        {
                            <div class="producto-rating">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= producto.Estrellas)
                                    {
                                        <i class="bi bi-star-fill"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star"></i>
                                    }
                                }
                                <span class="rating-value">@producto.Estrellas</span>
                            </div>
                        }

                        <div class="producto-precio">@producto.Precio.ToString("C")</div>
                    </div>
                </a>
            </div>
        }
    </div>
}
else if (esBusqueda)
{
    <div class="sin-resultados">
        <i class="bi bi-search"></i>
        <h2>No se encontraron productos</h2>
        <p>No hay productos que coincidan con "<strong>@termino</strong>"</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Volver al inicio</a>
    </div>
}