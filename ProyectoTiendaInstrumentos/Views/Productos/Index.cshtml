@model List<VwCatalogoProducto>
@{
    ViewData["Title"] = "Catálogo";
    string termino = ViewBag.TerminoBusqueda ?? "";
    int numResultados = ViewBag.NumeroResultados ?? 0;
    bool esBusqueda = !string.IsNullOrEmpty(termino);

    List<Especificacion> specs = ViewBag.Specs as List<Especificacion>;
    Subtipo subtipo = ViewBag.Subtipo as Subtipo;

    int? idEspecificacionSeleccionada = ViewBag.IdEspecificacionSeleccionada as int?;
    List<ValoresEspecificacion> valores = ViewBag.ValoresEspecificacion as List<ValoresEspecificacion>;

    decimal precioMin = Model != null && Model.Count > 0 ? Math.Floor(Model.Min(p => p.Precio)) : 0;
    decimal precioMax = Model != null && Model.Count > 0 ? Math.Ceiling(Model.Max(p => p.Precio)) : 9999;
}

@if (esBusqueda)
{
    <div class="busqueda-header">
        <h1>Resultados de búsqueda</h1>
        <p class="termino-busqueda">
            Búsqueda: <strong>"@termino"</strong>
            <span class="num-resultados">(<span id="js-count-visible">@numResultados</span> @(numResultados == 1 ? "producto encontrado" : "productos encontrados"))</span>
        </p>
    </div>
}
else
{
    <h1>@(subtipo != null ? subtipo.Nombre : "Catálogo")</h1>
    <p>
        @(subtipo != null ? Html.ActionLink(subtipo.Nombre, "Index", "Subtipos", new { idTipo = subtipo.IdTipo }, null) : null)
    </p>
}

@if (Model != null && Model.Count > 0)
{
    if (esBusqueda)
    {
        <div class="filtros filtros-busqueda">
            <h3>Filtrar:</h3>
            <div class="filtros-especificaciones">

                <div class="filtro-especificacion" id="filtro-precio">
                    <a class="filtro-especificacion-titulo js-filtro-gen" href="#" data-target="panel-precio">
                        Precio
                    </a>
                    <div class="js-valores-host">
                        <div class="filtro-valores filtro-panel" id="panel-precio" style="display:none; flex-direction:column; gap:0.75rem;">
                            <div class="filtro-rango-row">
                                <label>Min: <strong id="lbl-precio-min">@precioMin.ToString("0")€</strong></label>
                                <label>Max: <strong id="lbl-precio-max">@precioMax.ToString("0")€</strong></label>
                            </div>
                            <input type="range" id="range-precio-min" class="filtro-range" min="@precioMin.ToString("0")" max="@precioMax.ToString("0")" value="@precioMin.ToString("0")" step="1" />
                            <input type="range" id="range-precio-max" class="filtro-range" min="@precioMin.ToString("0")" max="@precioMax.ToString("0")" value="@precioMax.ToString("0")" step="1" />
                        </div>
                    </div>
                </div>

                <div class="filtro-especificacion" id="filtro-valoracion">
                    <a class="filtro-especificacion-titulo js-filtro-gen" href="#" data-target="panel-valoracion">
                        Valoración mínima
                    </a>
                    <div class="js-valores-host">
                        <div class="filtro-valores filtro-panel" id="panel-valoracion" style="display:none;">
                            @for (int i = 1; i <= 5; i++)
                            {
                                int stars = i;
                                <a class="filtro-valor js-filtro-estrellas" href="#" data-estrellas="@stars">
                                    @for (int s = 1; s <= stars; s++) { <i class="bi bi-star-fill"></i> }
                                    @for (int s = stars + 1; s <= 5; s++) { <i class="bi bi-star"></i> }
                                </a>
                            }
                            <a class="filtro-valor js-filtro-estrellas filtro-valor-activo" href="#" data-estrellas="0">Todas</a>
                        </div>
                    </div>
                </div>

                <div class="filtro-especificacion" id="filtro-stock">
                    <a class="filtro-especificacion-titulo js-filtro-gen" href="#" data-target="panel-stock">
                        Disponibilidad
                    </a>
                    <div class="js-valores-host">
                        <div class="filtro-valores filtro-panel" id="panel-stock" style="display:none;">
                            <a class="filtro-valor js-filtro-stock filtro-valor-activo" href="#" data-stock="all">Todos</a>
                            <a class="filtro-valor js-filtro-stock" href="#" data-stock="available">En stock</a>
                            <a class="filtro-valor js-filtro-stock" href="#" data-stock="low">Pocas unidades</a>
                            <a class="filtro-valor js-filtro-stock" href="#" data-stock="out">Agotados</a>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    }
    else if (specs != null && specs.Count > 0)
    {
        <div class="filtros">
            <h3>Filtrar:</h3>
            <div class="filtros-especificaciones">
                @foreach (Especificacion spec in specs)
                {
                    <div class="filtro-especificacion">
                        <a class="filtro-especificacion-titulo js-spec"
                           href="#"
                           data-idsubtipo="@(subtipo?.IdSubtipo ?? 0)"
                           data-idespecificacion="@spec.IdEspecificacion">
                            @spec.Nombre
                        </a>
                        <div class="js-valores-host" data-idespecificacion="@spec.IdEspecificacion"></div>
                    </div>
                }

                <div class="filtro-especificacion" id="filtro-precio">
                    <a class="filtro-especificacion-titulo js-filtro-gen" href="#" data-target="panel-precio">
                        Precio
                    </a>
                    <div class="js-valores-host">
                        <div class="filtro-valores filtro-panel" id="panel-precio" style="display:none; flex-direction:column; gap:0.75rem;">
                            <div class="filtro-rango-row">
                                <label>Min: <strong id="lbl-precio-min">@precioMin.ToString("0")€</strong></label>
                                <label>Max: <strong id="lbl-precio-max">@precioMax.ToString("0")€</strong></label>
                            </div>
                            <input type="range" id="range-precio-min" class="filtro-range" min="@precioMin.ToString("0")" max="@precioMax.ToString("0")" value="@precioMin.ToString("0")" step="1" />
                            <input type="range" id="range-precio-max" class="filtro-range" min="@precioMin.ToString("0")" max="@precioMax.ToString("0")" value="@precioMax.ToString("0")" step="1" />
                        </div>
                    </div>
                </div>

                <div class="filtro-especificacion" id="filtro-valoracion">
                    <a class="filtro-especificacion-titulo js-filtro-gen" href="#" data-target="panel-valoracion">
                        Valoración mínima
                    </a>
                    <div class="js-valores-host">
                        <div class="filtro-valores filtro-panel" id="panel-valoracion" style="display:none;">
                            @for (int i = 1; i <= 5; i++)
                            {
                                int stars = i;
                                <a class="filtro-valor js-filtro-estrellas" href="#" data-estrellas="@stars">
                                    @for (int s = 1; s <= stars; s++) { <i class="bi bi-star-fill"></i> }
                                    @for (int s = stars + 1; s <= 5; s++) { <i class="bi bi-star"></i> }
                                </a>
                            }
                            <a class="filtro-valor js-filtro-estrellas filtro-valor-activo" href="#" data-estrellas="0">Todas</a>
                        </div>
                    </div>
                </div>

                <div class="filtro-especificacion" id="filtro-stock">
                    <a class="filtro-especificacion-titulo js-filtro-gen" href="#" data-target="panel-stock">
                        Disponibilidad
                    </a>
                    <div class="js-valores-host">
                        <div class="filtro-valores filtro-panel" id="panel-stock" style="display:none;">
                            <a class="filtro-valor js-filtro-stock filtro-valor-activo" href="#" data-stock="all">Todos</a>
                            <a class="filtro-valor js-filtro-stock" href="#" data-stock="available">En stock</a>
                            <a class="filtro-valor js-filtro-stock" href="#" data-stock="low">Pocas unidades</a>
                            <a class="filtro-valor js-filtro-stock" href="#" data-stock="out">Agotados</a>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    }

    <div class="js-productos-host">
        @await Html.PartialAsync("_ProductosGrid", Model)
    </div>

    <div class="sin-resultados-filtro" id="js-no-results" style="display:none;">
        <i class="bi bi-funnel"></i>
        <h2>Sin resultados</h2>
        <p>Ningún producto coincide con los filtros aplicados.</p>
    </div>
}
else if (esBusqueda)
{
    <div class="sin-resultados">
        <i class="bi bi-search"></i>
        <h2>No se encontraron productos</h2>
        <p>No hay productos que coincidan con "<strong>@termino</strong>"</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Volver al inicio</a>
    </div>
}

@section Scripts {
    <script>
        $(function () {

            // ── Estado de filtros generales ───────────────────────────────────────
            var filtroEstrellasMin = 0;
            var filtroStock = 'all';
            var filtroPrecioMin = parseFloat($('#range-precio-min').val()) || 0;
            var filtroPrecioMax = parseFloat($('#range-precio-max').val()) || 999999;

            function applyFiltrosGenerales() {
                var visible = 0;
                $('.producto-card').each(function () {
                    var $card = $(this);
                    var precio = parseFloat($card.data('precio') || 0);
                    var estrellas = parseInt($card.data('estrellas') || 0);
                    var stock = parseInt($card.data('stock') || 0);

                    var stockOk = true;
                    if (filtroStock === 'available') stockOk = stock >= 5;
                    else if (filtroStock === 'low') stockOk = stock > 0 && stock < 5;
                    else if (filtroStock === 'out') stockOk = stock <= 0;

                    // filtroPrecioMin es floor del mínimo, filtroPrecioMax es ceil del máximo.
                    // Comparamos precio < filtroPrecioMin+1 (para incluir decimales dentro del tramo)
                    // y precio <= filtroPrecioMax (ceil ya cubre los decimales por arriba)
                    var ok = precio >= filtroPrecioMin
                          && precio < (filtroPrecioMax + 1)
                          && estrellas >= filtroEstrellasMin
                          && stockOk;

                    $card.toggle(ok);
                    if (ok) visible++;
                });

                $('#js-count-visible').text(visible);
                $('#js-no-results').toggle(visible === 0);
            }

            // Toggle panel accordion (filtros generales)
            $(document).on('click', '.js-filtro-gen', function (e) {
                e.preventDefault();
                var target = $(this).data('target');
                var $panel = $('#' + target);
                var $link = $(this);
                var $container = $link.closest('.filtro-especificacion');
                var isVisible = $panel.is(':visible');

                $('.filtro-panel').stop(true, true).slideUp(200);
                $('.js-filtro-gen').removeClass('is-active');
                $('.filtro-especificacion[id^="filtro-"]').removeClass('is-expanded');

                if (!isVisible) {
                    $panel.stop(true, true).slideDown(200);
                    $link.addClass('is-active');
                    $container.addClass('is-expanded');
                }
            });

            // Precio range
            $('#range-precio-min').on('input', function () {
                filtroPrecioMin = parseFloat($(this).val());
                if (filtroPrecioMin > filtroPrecioMax) {
                    $(this).val(filtroPrecioMax);
                    filtroPrecioMin = filtroPrecioMax;
                }
                $('#lbl-precio-min').text(filtroPrecioMin + '€');
                applyFiltrosGenerales();
            });

            $('#range-precio-max').on('input', function () {
                filtroPrecioMax = parseFloat($(this).val());
                if (filtroPrecioMax < filtroPrecioMin) {
                    $(this).val(filtroPrecioMin);
                    filtroPrecioMax = filtroPrecioMin;
                }
                $('#lbl-precio-max').text(filtroPrecioMax + '€');
                applyFiltrosGenerales();
            });

            // Estrellas
            $(document).on('click', '.js-filtro-estrellas', function (e) {
                e.preventDefault();
                filtroEstrellasMin = parseInt($(this).data('estrellas'));
                $('.js-filtro-estrellas').removeClass('filtro-valor-activo');
                $(this).addClass('filtro-valor-activo');
                applyFiltrosGenerales();
            });

            // Stock
            $(document).on('click', '.js-filtro-stock', function (e) {
                e.preventDefault();
                filtroStock = $(this).data('stock');
                $('.js-filtro-stock').removeClass('filtro-valor-activo');
                $(this).addClass('filtro-valor-activo');
                applyFiltrosGenerales();
            });

            // ── Filtros por especificación (catálogo) ─────────────────────────────

            function closeAllValores() {
                // Solo cierra los paneles de especificaciones dinámicas, no los filtros generales
                $('.js-spec').each(function () {
                    var $host = $(this).closest('.filtro-especificacion').find('.js-valores-host');
                    $host.find('.filtro-valores:visible').stop(true, true).slideUp(200);
                });
                $('.js-spec').removeClass('is-active is-loading');
                $('.filtro-especificacion:not([id^="filtro-"])').removeClass('is-expanded');
            }

            $('.js-spec').on('click', function (e) {
                e.preventDefault();

                var $link = $(this);
                var idSubtipo = $link.data('idsubtipo');
                var idEspecificacion = $link.data('idespecificacion');

                var $container = $link.closest('.filtro-especificacion');
                var $host = $container.find('.js-valores-host');

                var $existing = $host.find('.filtro-valores');
                if ($existing.length) {
                    var isVisible = $existing.is(':visible');
                    closeAllValores();

                    if (!isVisible) {
                        $link.addClass('is-active');
                        $container.addClass('is-expanded');
                        $existing.stop(true, true).slideDown(200);
                    }

                    return;
                }

                closeAllValores();
                $link.addClass('is-loading');

                $.get('@Url.Action("ValoresEspecificacionPartial", "Productos")', {
                    idSubtipo: idSubtipo,
                    idEspecificacion: idEspecificacion
                })
                    .done(function (html) {
                        $link.removeClass('is-loading').addClass('is-active');
                        $container.addClass('is-expanded');
                        $host.html(html);
                        $host.find('.filtro-valores').stop(true, true).slideDown(200);
                    })
                    .fail(function () {
                        $link.removeClass('is-loading');
                        alert('Error al cargar los valores. Por favor, inténtalo de nuevo.');
                    });
            });

            $(document).on('click', '.js-valor', function (e) {
                e.preventDefault();

                var $valor = $(this);
                var valor = $valor.data('valor');

                var $specContainer = $valor.closest('.filtro-especificacion');
                var $specLink = $specContainer.find('.js-spec');

                var idSubtipo = $specLink.data('idsubtipo');
                var idEspecificacion = $specLink.data('idespecificacion');

                var yaActivo = $valor.hasClass('filtro-valor-activo');

                $specContainer.find('.js-valor').removeClass('filtro-valor-activo');
                $specLink.removeClass('tiene-filtro-activo');

                if (yaActivo) {
                    // Deseleccionar: restaurar todos los productos del subtipo
                    $.get('@Url.Action("TodosLosProductosPartial", "Productos")', {
                        idSubtipo: idSubtipo
                    })
                        .done(function (html) {
                            $('.js-productos-host').html(html);
                            applyFiltrosGenerales();
                        })
                        .fail(function () {
                            alert('Error al restablecer productos.');
                        });
                    return;
                }

                // Seleccionar: marcar valor como activo y filtrar
                $valor.addClass('filtro-valor-activo');
                $specLink.addClass('tiene-filtro-activo');

                $.get('@Url.Action("FiltrarPorValor", "Productos")', {
                    idSubtipo: idSubtipo,
                    idEspecificacion: idEspecificacion,
                    valor: valor
                })
                    .done(function (html) {
                        $('.js-productos-host').html(html);
                        applyFiltrosGenerales();
                    })
                    .fail(function () {
                        alert('Error al filtrar productos.');
                    });
            });
        });
    </script>
}