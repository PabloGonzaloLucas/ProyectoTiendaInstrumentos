@model List<Marca>


    <div>
        <h1 class="page-title">Marcas</h1>
        @if (Context.User.FindFirst("Admin") != null)
        {
            <button type="button">Añadir Marca</button>
            <form method="post" asp-controller="Productos" asp-action="CreateMarca" enctype="multipart/form-data">
                <label>Nombre</label>
                <input type="text" name="Nombre" />
                <label>Logo</label>
                <input type="file" name="Logo" />
                <button type="submit" name="accion" value="add">Añadir</button>
                <button type="submit" name="accion" value="cancelar">Cancelar</button>
            </form>
        }
        @if (Model.Count > 0)
        {
            @if (Context.User.FindFirst("Admin") != null)
            {
                @foreach (Marca marca in Model)
                {
                    <div>
                        <a asp-controller="Productos" asp-action="Index" asp-route-idMarca="@marca.IdMarca">
                            <img src="~/images/marcas/@marca.Logo" alt="Logo @marca.Nombre">
                            <h1>
                                @marca.Nombre
                            </h1>
                            @if (marca.Puntuacion > 0)
                            {
                                <div class="producto-rating">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= marca.Puntuacion)
                                        {
                                            <i class="bi bi-star-fill"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star"></i>
                                        }
                                    }
                                    <span class="rating-value">@marca.Puntuacion</span>
                                </div>
                            }
                        </a>
                        <a asp-controller="Productos" asp-action="EditMarca" asp-route-idMarca="@marca.IdMarca">
                            Editar
                        </a>
                        <form method="post" asp-action="DeleteMarca" asp-controller="Productos">
                            <input type="hidden" name="idMarca" value="@marca.IdMarca" />
                            <button type="submit">Eliminar</button>
                        </form>
                    </div>
            }
        }
        else
        {
            @foreach (Marca marca in Model)
            {
                <div>
                    <a asp-controller="Productos" asp-action="Index" asp-route-idMarca="@marca.IdMarca">
                        <img src="~/images/marcas/@marca.Logo" alt="Logo @marca.Nombre">
                        <h1>
                            @marca.Nombre
                        </h1>
                        @if (marca.Puntuacion > 0)
                        {
                            <div class="producto-rating">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= marca.Puntuacion)
                                    {
                                        <i class="bi bi-star-fill"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star"></i>
                                    }
                                }
                                <span class="rating-value">@marca.Puntuacion</span>
                            </div>
                        }
                    </a>

                </div>
            }
        }


    }
        else
        {
            <div>
                <h1>No hay marcas disponibles</h1>
            </div>
        }
    </div>
    
