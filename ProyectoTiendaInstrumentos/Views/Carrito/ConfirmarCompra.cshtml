@model List<VwCatalogoProducto>
@{
    decimal total = 0;
}
<h1>Carrito</h1>
@if (Model != null && Model.Count > 0)
{
    <form method="post" asp-action="ConfirmarCompra">
        <ul>
            @for (int index = 0; index < Model.Count; index++)
            {
                VwCatalogoProducto producto = Model[index];
                <li>
                    <a asp-controller="Productos" asp-action="Details" asp-route-idProducto="@producto.IdProducto">
                        <img src="~/images/productosMain/@producto.ImagenPrincipal" alt="@producto.Modelo" />
                        <p>
                            <span style="font-weight:400">
                                @(producto.Marca + " ")
                            </span>
                            <span>
                                @producto.Modelo
                            </span>
                        </p>
                        <span>
                            @producto.Precio €
                        </span>
                        <span>
                            x @(producto.Cantidad ?? 0)
                        </span>
                    </a>
                </li>

                <input type="hidden" name="productos[@index].IdProducto" value="@producto.IdProducto" />
                <input type="hidden" name="productos[@index].Cantidad" value="@(producto.Cantidad ?? 0)" />

                
                    decimal precio = producto.Precio;
                    int cantidad = producto.Cantidad ?? 0;
                    total += precio * cantidad;
                
            }
        </ul>

        <div class="carrito-resumen">
            <p>
                <strong>Total: </strong>
                <span class="total-precio">@total €</span>
            </p>
            <button type="submit" name="accion" value="confirmar" class="btn-comprar">
                Confirmar compra
            </button>
            <button type="submit" name="accion" value="cancelar" class="btn-secondary">
                Cancelar
            </button>
        </div>
    </form>

}
else
{
    <div class="carrito-vacio">
        <i class="bi bi-cart-x"></i>
        <h2>Error al obtener los productos</h2>
    </div>
}