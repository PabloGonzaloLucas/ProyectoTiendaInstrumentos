@model List<VwCatalogoProducto>
@using ProyectoTiendaInstrumentos.Models
@{
    PagedResult<VwCatalogoProducto>? paginacionCarrito = ViewBag.PaginacionCarrito as PagedResult<VwCatalogoProducto>;
    int offsetIndex = paginacionCarrito != null ? (paginacionCarrito.PaginaActual - 1) * paginacionCarrito.TamañoPagina : 0;
}

<h1 class="carrito-titulo">Carrito</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger" role="alert">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success" role="alert">@TempData["Success"]</div>
}
@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-info" role="alert">@TempData["Mensaje"]</div>
}

@if (Model != null && Model.Count > 0)
{
    <form method="post" asp-action="ProcesarCompra">
        @Html.AntiForgeryToken()
        <ul class="carrito-lista">
            @for (int index = 0; index < Model.Count; index++)
            {
                VwCatalogoProducto producto = Model[index];
                int realIndex = offsetIndex + index;
                <li class="carrito-item">
                    <a asp-controller="Productos" asp-action="Details" asp-route-idProducto="@producto.IdProducto" class="carrito-item-link">
                        <div class="carrito-item-info">
                            <span class="carrito-item-marca">@producto.Marca</span>
                            <span class="carrito-item-nombre">@producto.Modelo</span>
                            @if (producto.Stock < 5 && producto.Stock > 0)
                            {
                                <span class="carrito-item-stock-low"><i class="bi bi-exclamation-triangle"></i> Pocas unidades</span>
                            }
                            else if (producto.Stock >= 5)
                            {
                                <span class="carrito-item-stock-ok"><i class="bi bi-check-circle"></i> En stock</span>
                            }
                            else if (producto.Stock < 1)
                            {
                                <span class="carrito-item-stock-out"><i class="bi bi-x-circle"></i> Sin stock</span>
                            }
                        </div>

                        <div class="carrito-item-imgwrap">
                            <img src="~/images/productosMain/@producto.ImagenPrincipal"
                                 alt="@producto.Modelo"
                                 class="carrito-item-img"
                                 style="display:block;width:170px;height:170px;min-width:170px;min-height:170px;max-width:170px;max-height:170px;object-fit:contain;object-position:center;margin:0 auto;" />
                        </div>

                        <div class="carrito-item-price">
                            <span class="carrito-item-precio precio-unitario" data-precio="@producto.Precio">@producto.Precio €</span>
                        </div>
                    </a>

                    <div class="carrito-item-actions">
                        <input type="hidden" name="productos[@realIndex].IdProducto" value="@producto.IdProducto" />
                        <select name="productos[@realIndex].Cantidad"
                                class="carrito-cantidad-select cantidad-select"
                                data-idproducto="@producto.IdProducto"
                                data-precio="@producto.Precio">
                            @{
                                int stock = producto.Stock ?? 0;
                                int maxCantidad = Math.Min(10, stock);
                                int cantidadActual = producto.Cantidad ?? 1;
                            }
                            @for (int i = 1; i <= maxCantidad; i++)
                            {
                                <option value="@i" selected="@(i == cantidadActual)">@i</option>
                            }
                        </select>

                        <span class="carrito-subtotal-linea subtotal-linea" data-idproducto="@producto.IdProducto">
                            @(producto.Precio * (producto.Cantidad ?? 1)) €
                        </span>

                        <button type="submit"
                                asp-action="EliminarProducto"
                                asp-route-idProducto="@producto.IdProducto"
                                class="carrito-btn-eliminar"
                                onclick="return confirm('¿Eliminar este producto del carrito?')">
                            <i class="bi bi-trash"></i> Eliminar
                        </button>
                    </div>
                </li>
            }
        </ul>

        <div class="carrito-resumen">
            <span class="carrito-resumen-texto">Total:</span>
            <span class="carrito-resumen-total total-precio">
                @Model.Sum(p => p.Precio * (p.Cantidad ?? 1)) €
            </span>
            <button type="submit" class="carrito-btn-comprar">
                <i class="bi bi-bag-check"></i> Procesar compra
            </button>
        </div>
    </form>

    @if (paginacionCarrito != null)
    {
        @await Html.PartialAsync("_Paginacion", (
            paginacionCarrito.PaginaActual,
            paginacionCarrito.TotalPaginas,
            "Index",
            "Carrito",
            (object)(new { })
        ))
    }

    <form method="post" asp-action="VaciarCarrito" style="margin-top: 0.75rem;">
        @Html.AntiForgeryToken()
        <button type="submit" class="carrito-btn-vaciar" onclick="return confirm('¿Vaciar el carrito?')">
            <i class="bi bi-trash3"></i> Vaciar carrito
        </button>
    </form>

    <script>
        (function () {
            function parseDecimal(value) {
                if (value === null || value === undefined) return 0;
                var normalized = String(value).replace(',', '.');
                var n = Number(normalized);
                return Number.isFinite(n) ? n : 0;
            }

            function formatEuros(value) {
                return value.toFixed(2) + ' €';
            }

            function recalcular() {
                var total = 0;
                document.querySelectorAll('select.cantidad-select').forEach(function (select) {
                    var precio = parseDecimal(select.getAttribute('data-precio'));
                    var cantidad = parseDecimal(select.value);
                    var id = select.getAttribute('data-idproducto');
                    var subtotal = precio * cantidad;
                    total += subtotal;
                    var subtotalSpan = document.querySelector('.subtotal-linea[data-idproducto="' + id + '"]');
                    if (subtotalSpan) subtotalSpan.textContent = formatEuros(subtotal);
                });
                var totalSpan = document.querySelector('.total-precio');
                if (totalSpan) totalSpan.textContent = formatEuros(total);
            }

            document.querySelectorAll('select.cantidad-select').forEach(function (select) {
                select.addEventListener('change', recalcular);
            });
            recalcular();
        })();
    </script>
}
else
{
    <div class="carrito-vacio">
        <i class="bi bi-cart-x"></i>
        <h2>Tu carrito está vacío</h2>
        <p>Añade productos para comenzar tu compra</p>
        <a asp-controller="Tipos" asp-action="Index" class="carrito-btn-continuar">
            Continuar comprando
        </a>
    </div>
}