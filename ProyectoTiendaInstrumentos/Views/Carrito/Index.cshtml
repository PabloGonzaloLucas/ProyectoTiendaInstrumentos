@model List<VwCatalogoProducto>

<h1>Carrito</h1>
@if (Model != null && Model.Count > 0)
{
    <form method="post" asp-action="ProcesarCompra">
        <ul>
            @for (int index = 0; index < Model.Count; index++)
            {
                VwCatalogoProducto producto = Model[index];
                <li>
                    <a asp-controller="Productos" asp-action="Details" asp-route-idProducto="@producto.IdProducto">
                        <img src="~/images/productosMain/@producto.ImagenPrincipal" alt="@producto.Modelo" />
                        <p>
                            <span style="font-weight:400">
                                @(producto.Marca + " ")
                            </span>
                            <span>
                                @producto.Modelo
                            </span>
                        </p>

                        <span class="precio-unitario" data-precio="@producto.Precio">
                            @producto.Precio €
                        </span>

                        @if (producto.Stock < 5 && producto.Stock > 0)
                        {
                            <span style="color:orange">Quedan pocas unidades!</span>
                        }
                        else if (producto.Stock >= 5)
                        {
                            <span style="color:green">En stock!</span> 
                        }
                        else if (producto.Stock < 1)
                        {
                            <span style="color:red">No hay stock</span>
                        }
                    </a>

                    <div class="producto-actions">
                        <input type="hidden" name="productos[@index].IdProducto" value="@producto.IdProducto" />

                        <select name="productos[@index].Cantidad"
                                class="cantidad-select"
                                data-idproducto="@producto.IdProducto"
                                data-precio="@producto.Precio">
                            @{
                                int stock = producto.Stock ?? 0;
                                int maxCantidad = Math.Min(10, stock);
                                int cantidadActual = producto.Cantidad ?? 1;
                            }
                            @for (int i = 1; i <= maxCantidad; i++)
                            {
                                <option value="@i" selected="@(i == cantidadActual)">
                                    @i
                                </option>
                            }
                        </select>

                        <span class="subtotal-linea" data-idproducto="@producto.IdProducto">
                            @(producto.Precio * (producto.Cantidad ?? 1)) €
                        </span>

                        <button type="submit"
                                asp-action="EliminarProducto"
                                asp-route-idProducto="@producto.IdProducto"
                                class="btn-eliminar">
                            <i class="bi bi-trash"></i> Eliminar
                        </button>
                    </div>
                </li>
            }
        </ul>

        <div class="carrito-resumen">
            <p>
                <strong>Total: </strong>
                <span class="total-precio">
                    @Model.Sum(p => p.Precio * (p.Cantidad ?? 1)) €
                </span>
            </p>
            <button type="submit" class="btn-comprar">
                Procesar compra
            </button>
        </div>
    </form>

    <form method="post" asp-action="VaciarCarrito" style="margin-top: 1rem;">
        <button type="submit" class="btn-secondary">
            Vaciar carrito
        </button>
    </form>

    <script>
        (function () {
            function parseDecimal(value) {
                if (value === null || value === undefined) return 0;
                var normalized = String(value).replace(',', '.');
                var n = Number(normalized);
                return Number.isFinite(n) ? n : 0;
            }

            function formatEuros(value) {
                return value.toFixed(2) + ' €';
            }

            function recalcular() {
                var total = 0;

                document.querySelectorAll('select.cantidad-select').forEach(function (select) {
                    var precio = parseDecimal(select.getAttribute('data-precio'));
                    var cantidad = parseDecimal(select.value);
                    var id = select.getAttribute('data-idproducto');

                    var subtotal = precio * cantidad;
                    total += subtotal;

                    var subtotalSpan = document.querySelector('.subtotal-linea[data-idproducto="' + id + '"]');
                    if (subtotalSpan) {
                        subtotalSpan.textContent = formatEuros(subtotal);
                    }
                });

                var totalSpan = document.querySelector('.total-precio');
                if (totalSpan) {
                    totalSpan.textContent = formatEuros(total);
                }
            }

            document.querySelectorAll('select.cantidad-select').forEach(function (select) {
                select.addEventListener('change', recalcular);
            });

            recalcular();
        })();
    </script>
}
else
{
    <div class="carrito-vacio">
        <i class="bi bi-cart-x"></i>
        <h2>Tu carrito está vacío</h2>
        <p>Añade productos para comenzar tu compra</p>
        <a asp-controller="Tipos" asp-action="Index" class="btn-continuar">
            Continuar comprando
        </a>
    </div>
}