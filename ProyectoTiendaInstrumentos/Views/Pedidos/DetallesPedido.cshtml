@model Pedido
@using ProyectoTiendaInstrumentos.Models
@{
    PagedResult<VwProductosPedido>? paginacionProductos = ViewBag.PaginacionProductos as PagedResult<VwProductosPedido>;
    // bool entregado = Model.FechaEntrega.HasValue && Model.FechaEntrega.Value < DateTime.Now;
    // string estadoMostrar = entregado ? "Entregado" : Model.Estado;
}

<a asp-controller="Pedidos" asp-action="MisPedidos" class="detpedido-volver">
    <i class="bi bi-arrow-left"></i> Volver a mis pedidos
</a>

<h1 class="detpedido-titulo">Pedido #@Model.IdPedido</h1>

<div class="detpedido-resumen">
    <span class="detpedido-total">@Model.PrecioTotal.ToString("C")</span>
    <span class="detpedido-estado">@Model.Estado</span>
    <span class="detpedido-fecha-entrega"><i class="bi bi-truck"></i> Entrega: @Model.FechaEntrega?.ToString("dd/MM/yyyy")</span>
</div>

<ul class="detpedido-lista">
    @if (Model.ProductosPedido != null)
    {
        @foreach (VwProductosPedido producto in Model.ProductosPedido)
        {
            <li>
                <a asp-controller="Productos" asp-action="Details" asp-route-idProducto="@producto.IdProducto" class="detpedido-producto-link">
                    <img src="~/images/productosMain/@producto.Imagen"
                         alt="@producto.Modelo"
                         class="detpedido-producto-img"
                         style="display:block;width:250px;height:250px;min-width:250px;min-height:250px;max-width:250px;max-height:250px;object-fit:contain;object-position:center;margin:0 auto;padding:4px;border-radius:10px;" />
                    <div class="detpedido-producto-info">
                        <span class="detpedido-producto-marca">@producto.Marca</span>
                        <span class="detpedido-producto-nombre">@producto.Modelo</span>
                        <div class="detpedido-producto-meta">
                            <span class="detpedido-producto-precio">@producto.PrecioUnitario.ToString("C")</span>
                            <span>x @producto.Cantidad</span>
                        </div>
                    </div>
                    <span class="detpedido-producto-subtotal">@producto.SubtotalLinea?.ToString("C")</span>
                </a>
            </li>
        }
    }
</ul>

@if (paginacionProductos != null)
{
    @await Html.PartialAsync("_Paginacion", (
        paginacionProductos.PaginaActual,
        paginacionProductos.TotalPaginas,
        "DetallesPedido",
        "Pedidos",
        (object)(new { idPedido = Model.IdPedido })
    ))
}

<div class="detpedido-footer">
    <i class="bi bi-calendar-check"></i>
    Pedido realizado el @Model.FechaCreacion?.ToString("dd/MM/yyyy HH:mm")
</div>