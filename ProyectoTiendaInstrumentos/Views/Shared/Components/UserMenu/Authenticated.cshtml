@model ProyectoTiendaInstrumentos.Models.Usuario

<ul class="navbar-nav">
    <li class="nav-item">
        @await Component.InvokeAsync("CartCount")
    </li>
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle text-dark" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            @if (!string.IsNullOrEmpty(Model?.Imagen))
            {
                <img src="@Model.Imagen" alt="" class="rounded-circle" style="width: 30px; height: 30px;" />
            }
            else
            {
                <i class="bi bi-person-circle"></i>
            }
            @Model?.Nombre
        </a>
        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
            <li>
                <a class="dropdown-item" asp-controller="Cuenta" asp-action="Perfil">
                    <i class="bi bi-person"></i> Mi Perfil
                </a>
            </li>
            <li>
                <a class="dropdown-item" asp-controller="Pedidos" asp-action="MisPedidos">
                    <i class="bi bi-box-seam"></i> Mis Pedidos
                </a>
            </li>
            <li><hr class="dropdown-divider"></li>
            <li>
                <form asp-controller="Cuenta" asp-action="Logout" method="post" class="d-inline">
                    <button type="submit" class="dropdown-item">
                        <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
                    </button>
                </form>
            </li>
        </ul>
    </li>
</ul>