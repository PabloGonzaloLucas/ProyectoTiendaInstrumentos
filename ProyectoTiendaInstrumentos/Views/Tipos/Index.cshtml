@model List<Tipo>
@{
    ViewData["Title"] = "Tipos de Instrumentos";
}

<h1 class="page-title">Tipos de Instrumentos</h1>

@if(Model.Count > 0)
{
    <ul class="tipos-grid">
        @foreach(Tipo tipo in Model)
        {
            <li>
                <a asp-controller="Subtipos" asp-action="Index" asp-route-idTipo="@tipo.IdTipo" class="tipo-card">
                    <span>@tipo.Nombre</span>
                </a>
            </li>
        }
    </ul>
}
else
{
    <div class="empty-message">
        <i class="bi bi-inbox"></i>
        <h2>No hay Tipos disponibles</h2>
    </div>
}