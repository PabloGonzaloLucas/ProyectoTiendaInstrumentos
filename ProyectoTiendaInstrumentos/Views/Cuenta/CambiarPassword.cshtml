@model Usuario
@{
    ViewData["Title"] = "Cambiar Contraseña";
}

<div class="register-container">
    <div class="register-card">
        <div class="text-center mb-4">
            <h1>Cambiar Contraseña</h1>
            <h4>Actualiza tu contraseña de acceso</h4>
        </div>

        <div class="mx-auto" style="max-width: 600px;">
            <form method="post" asp-action="CambiarPassword">
                <div class="form-group">
                    <label class="control-label">Contraseña Actual</label>
                    <input type="password" name="passwordActual" class="form-control" required />
                </div>

                <div class="form-group">
                    <label class="control-label">Nueva Contraseña</label>
                    <input type="password" name="passwordNueva" class="form-control" required minlength="6" />
                </div>

                <div class="form-group">
                    <label class="control-label">Confirmar Nueva Contraseña</label>
                    <input type="password" name="passwordConfirmar" class="form-control" required minlength="6" />
                </div>

                <div class="d-flex flex-column flex-sm-row justify-content-between gap-2 mt-4 pt-3" style="border-top: 2px solid var(--light-gray);">
                    <a class="btn btn-secondary" asp-controller="Cuenta" asp-action="Perfil">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Guardar Nueva Contraseña</button>
                </div>
            </form>

            @if (TempData["Error"] != null)
            {
                <div class="error-message mt-3">@TempData["Error"]</div>
            }

            @if (TempData["Success"] != null)
            {
                <div class="success-message mt-3">@TempData["Success"]</div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
