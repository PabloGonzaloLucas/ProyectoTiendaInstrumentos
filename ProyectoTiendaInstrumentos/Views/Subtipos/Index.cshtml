@model List<Subtipo>
@{
    Tipo tipo = ViewBag.Tipo as Tipo;
}
<p>
    <a asp-controller="Tipos" asp-action="Index" asp-route-idFamilia="@tipo.IdFamilia">@tipo.Nombre</a>
</p>
<ul>
    @foreach(Subtipo subtipo in Model)
    {
        <li>
            <a asp-controller="Productos" asp-action="Index" asp-route-idSubtipo="@subtipo.IdSubtipo">@subtipo.Nombre</a>
        </li>
    }
</ul>
