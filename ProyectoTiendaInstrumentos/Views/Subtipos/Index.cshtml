@model List<Subtipo>
@using ProyectoTiendaInstrumentos.Models
@{
    Tipo? tipo = ViewBag.Tipo as Tipo;
    ViewData["Title"] = tipo?.Nombre ?? "Subtipos";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger" role="alert">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success" role="alert">@TempData["Success"]</div>
}

@if (tipo != null)
{
    <div class="breadcrumb-nav">
        <a asp-controller="Tipos" asp-action="Index" asp-route-idFamilia="@tipo.IdFamilia">
            <i class="bi bi-arrow-left"></i> @tipo.Nombre
        </a>
    </div>

    <h1 class="page-title">@tipo.Nombre</h1>
}
else
{
    <h1 class="page-title">Subtipos</h1>
}

@if (Context.User.FindFirst("Admin") != null)
{
    <div class="admin-toolbar">
        <button type="button" class="admin-btn" onclick="document.getElementById('form-add-subtipo').classList.toggle('admin-form--visible')">
            <i class="bi bi-plus-circle"></i> Añadir Subtipo
        </button>
        <form id="form-add-subtipo" method="post" asp-controller="Subtipos" asp-action="Index"
              enctype="multipart/form-data" class="admin-form">
            @Html.AntiForgeryToken()
            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label>Nombre del subtipo</label>
                    <input type="text" name="Nombre" class="admin-input" required minlength="2" maxlength="100" placeholder="Ej: Guitarra eléctrica..." />
                    <input type="hidden" name="IdTipo" value="@(tipo?.IdTipo ?? 0)" />
                </div>
                <div class="admin-form-actions">
                    <button type="submit" name="accion" value="add" class="admin-btn admin-btn--primary">Añadir</button>
                    <button type="submit" name="accion" value="cancelar" class="admin-btn admin-btn--secondary">Cancelar</button>
                </div>
            </div>
        </form>
    </div>
}

@if (Model != null && Model.Count > 0)
{
    <ul class="subtipos-grid">
        @foreach (Subtipo subtipo in Model)
        {
            <li>
                <a asp-controller="Productos" asp-action="Index" asp-route-idSubtipo="@subtipo.IdSubtipo" class="subtipo-card">
                    <span>@subtipo.Nombre</span>
                    <i class="bi bi-arrow-right-short"></i>
                </a>
                @if (Context.User.FindFirst("Admin") != null)
                {
                    <form method="post" asp-controller="Subtipos" asp-action="EliminarPost" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="idSubtipo" value="@subtipo.IdSubtipo" />
                        <input type="hidden" name="idTipo" value="@subtipo.IdTipo" />
                        <button type="submit"
                                class="admin-btn admin-btn--sm admin-btn--delete"
                                onclick="return confirm('¿Eliminar este subtipo?')"
                                aria-label="Eliminar subtipo @subtipo.Nombre">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                }
            </li>
        }
    </ul>
}
else
{
    <div class="empty-message">
        <i class="bi bi-inbox"></i>
        <h2>No hay subtipos disponibles</h2>
    </div>
}
