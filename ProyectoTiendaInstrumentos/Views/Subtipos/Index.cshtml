@model List<Subtipo>
@{
    Tipo tipo = ViewBag.Tipo as Tipo;
    ViewData["Title"] = tipo?.Nombre ?? "Subtipos";
}

<div class="breadcrumb-nav">
    <a asp-controller="Tipos" asp-action="Index" asp-route-idFamilia="@tipo.IdFamilia">
        <i class="bi bi-arrow-left"></i> @tipo.Nombre
    </a>
</div>

<h1 class="page-title">@tipo.Nombre</h1>

@if (Context.User.FindFirst("Admin") != null)
{
    <button type="button">Añadir Subtipo</button>
    <form method="post" asp-controller="Subtipos" asp-action="Index" enctype="multipart/form-data">
        <label>Nombre</label>
        <input type="text" name="Nombre" />
        <input type="hidden" name="IdTipo" value="@tipo.IdTipo" />
        <button type="submit" name="accion" value="add">Añadir</button>
        <button type="submit" name="accion" value="cancelar">Cancelar</button>
    </form>

    <ul class="subtipos-grid">
        @foreach (Subtipo subtipo in Model)
        {
            <li>
                <a asp-controller="Productos" asp-action="Index" asp-route-idSubtipo="@subtipo.IdSubtipo" class="subtipo-card">
                    <span>@subtipo.Nombre</span>
                </a>
                <a asp-controller="Subtipos" asp-action="Eliminar" asp-route-idSubtipo="@subtipo.IdSubtipo" 
                asp-route-idTipo="@subtipo.IdTipo">
                    Eliminar
                </a>
            </li>
        }
    </ul>

}
else
{
    <ul class="subtipos-grid">
        @foreach(Subtipo subtipo in Model)
        {
            <li>
                <a asp-controller="Productos" asp-action="Index" asp-route-idSubtipo="@subtipo.IdSubtipo" class="subtipo-card">
                    <span>@subtipo.Nombre</span>
                </a>
            </li>
        }
    </ul>
    
}

